# Airpay V3 (UPI QR) — https://docs.airpay.co.in/v3/upi/generate-qr/
AIRPAY_MERCHANT_ID=
AIRPAY_USERNAME=
AIRPAY_PASSWORD=
AIRPAY_SECRET=
# Optional (V4 OAuth — not used by V3 flow)
AIRPAY_CLIENT_ID=
AIRPAY_CLIENT_SECRET=
# Domain whitelisted with Airpay (used as mer_dom base64)
AIRPAY_MER_DOM=https://vardrobe.in
BACKEND_URL=https://api.vardrobe.in

# MSG91 OTP — https://docs.msg91.com/otp
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
MSG91_DEBUG=false
MSG91_USE_SENDER=false
